<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VidConnect - Register</title>
    <link rel="stylesheet" href="/css/variables.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <div class="auth-container">

        <!-- Left Side - Branding -->
        <div class="auth-left">
            <div class="auth-branding">
                <div class="auth-logo">
                    <i class="fas fa-video"></i>
                    <span>VidConnect</span>
                </div>
                
                <h1>Start Your Journey</h1>
                <p>Join thousands of teams using VidConnect for secure meetings.</p>

                <div class="auth-features">
                    <div class="feature-item">
                        <i class="fas fa-shield-alt"></i>
                        <span>End-to-End Encrypted</span>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-robot"></i>
                        <span>AI-Powered</span>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-lock"></i>
                        <span>Privacy First</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Registration Form -->
        <div class="auth-right">
            
            <!-- Tab Navigation -->
            <div class="auth-tabs">
                <button class="tab-btn active" data-tab="admin">
                    <i class="fas fa-user-tie"></i>
                    Admin Register
                </button>
                <button class="tab-btn" data-tab="participant">
                    <i class="fas fa-user"></i>
                    Participant Register
                </button>
            </div>

            <!-- Admin Registration Tab -->
            <div class="tab-content active" id="admin-tab">
                <div class="auth-card">
                    <h2>Create Admin Account</h2>
                    <p class="auth-subtitle">Set up your admin profile</p>

                    <form class="auth-form" action="/api/register/admin" method="POST">
                        
                        <!-- Full Name Input -->
                        <div class="form-group">
                            <label for="admin-name">Full Name</label>
                            <div class="input-wrapper">
                                <i class="fas fa-user"></i>
                                <input 
                                    type="text" 
                                    id="admin-name"
                                    name="name"
                                    placeholder="Enter your full name"
                                    required
                                >
                            </div>
                        </div>

                        <!-- Company Input -->
                        <div class="form-group">
                            <label for="admin-company">Company Name</label>
                            <div class="input-wrapper">
                                <i class="fas fa-building"></i>
                                <input 
                                    type="text" 
                                    id="admin-company"
                                    name="company"
                                    placeholder="Enter company name"
                                    required
                                >
                            </div>
                        </div>

                        <!-- Email Input -->
                        <div class="form-group">
                            <label for="admin-email">Email Address</label>
                            <div class="input-wrapper">
                                <i class="fas fa-envelope"></i>
                                <input 
                                    type="email" 
                                    id="admin-email"
                                    name="email"
                                    placeholder="Enter your email"
                                    required
                                >
                            </div>
                        </div>

                        <!-- Password Input -->
                        <div class="form-group">
                            <label for="admin-password">Password</label>
                            <div class="input-wrapper">
                                <i class="fas fa-lock"></i>
                                <input 
                                    type="password" 
                                    id="admin-password"
                                    name="password"
                                    placeholder="Create a strong password"
                                    required
                                >
                                <button type="button" class="toggle-password" onclick="togglePassword('admin-password')">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Confirm Password Input -->
                        <div class="form-group">
                            <label for="admin-confirm">Confirm Password</label>
                            <div class="input-wrapper">
                                <i class="fas fa-lock"></i>
                                <input 
                                    type="password" 
                                    id="admin-confirm"
                                    name="confirmPassword"
                                    placeholder="Confirm password"
                                    required
                                >
                                <button type="button" class="toggle-password" onclick="togglePassword('admin-confirm')">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Terms Checkbox -->
                        <div class="form-checkbox">
                            <input type="checkbox" id="admin-terms" name="terms" required>
                            <label for="admin-terms">I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a></label>
                        </div>

                        <!-- Register Button -->
                        <button type="submit" class="auth-btn primary-btn">
                            <i class="fas fa-user-plus"></i>
                            Create Admin Account
                        </button>

                    </form>

                    <!-- Divider -->
                    <div class="auth-divider">
                        <span>or</span>
                    </div>

                    <!-- Social Registration -->
                    <div class="social-login">
                        <button class="social-btn google-btn">
                            <i class="fab fa-google"></i>
                            Google
                        </button>
                        <button class="social-btn microsoft-btn">
                            <i class="fab fa-microsoft"></i>
                            Microsoft
                        </button>
                    </div>

                    <!-- Footer Links -->
                    <div class="auth-footer">
                        Already have an account?
                        <a href="/login" class="link">Login here</a>
                    </div>
                </div>
            </div>

            <!-- Participant Registration Tab -->
            <div class="tab-content" id="participant-tab">
                <div class="auth-card">
                    <h2>Join as Participant</h2>
                    <p class="auth-subtitle">Create your participant account</p>

                    <form class="auth-form" action="/api/register/participant" method="POST">
                        
                        <!-- Full Name Input -->
                        <div class="form-group">
                            <label for="participant-name">Full Name</label>
                            <div class="input-wrapper">
                                <i class="fas fa-user"></i>
                                <input 
                                    type="text" 
                                    id="participant-name"
                                    name="name"
                                    placeholder="Enter your full name"
                                    required
                                >
                            </div>
                        </div>

                        <!-- Email Input -->
                        <div class="form-group">
                            <label for="participant-email">Email Address</label>
                            <div class="input-wrapper">
                                <i class="fas fa-envelope"></i>
                                <input 
                                    type="email" 
                                    id="participant-email"
                                    name="email"
                                    placeholder="Enter your email"
                                    required
                                >
                            </div>
                        </div>

                        <!-- Phone Input -->
                        <div class="form-group">
                            <label for="participant-phone">Phone Number</label>
                            <div class="input-wrapper">
                                <i class="fas fa-phone"></i>
                                <input 
                                    type="tel" 
                                    id="participant-phone"
                                    name="phone"
                                    placeholder="Enter your phone number"
                                    required
                                >
                            </div>
                        </div>

                        <!-- Password Input -->
                        <div class="form-group">
                            <label for="participant-password">Password</label>
                            <div class="input-wrapper">
                                <i class="fas fa-lock"></i>
                                <input 
                                    type="password" 
                                    id="participant-password"
                                    name="password"
                                    placeholder="Create a strong password"
                                    required
                                >
                                <button type="button" class="toggle-password" onclick="togglePassword('participant-password')">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Confirm Password Input -->
                        <div class="form-group">
                            <label for="participant-confirm">Confirm Password</label>
                            <div class="input-wrapper">
                                <i class="fas fa-lock"></i>
                                <input 
                                    type="password" 
                                    id="participant-confirm"
                                    name="confirmPassword"
                                    placeholder="Confirm password"
                                    required
                                >
                                <button type="button" class="toggle-password" onclick="togglePassword('participant-confirm')">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Terms Checkbox -->
                        <div class="form-checkbox">
                            <input type="checkbox" id="participant-terms" name="terms" required>
                            <label for="participant-terms">I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a></label>
                        </div>

                        <!-- Register Button -->
                        <button type="submit" class="auth-btn primary-btn">
                            <i class="fas fa-user-plus"></i>
                            Create Participant Account
                        </button>

                    </form>

                    <!-- Divider -->
                    <div class="auth-divider">
                        <span>or</span>
                    </div>

                    <!-- Social Registration -->
                    <div class="social-login">
                        <button class="social-btn google-btn">
                            <i class="fab fa-google"></i>
                            Google
                        </button>
                        <button class="social-btn microsoft-btn">
                            <i class="fab fa-microsoft"></i>
                            Microsoft
                        </button>
                    </div>

                    <!-- Footer Links -->
                    <div class="auth-footer">
                        Already have an account?
                        <a href="/login" class="link">Login here</a>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <script>
        // Tab Switching
        document.querySelectorAll('.tab-btn').forEach(button => {
            button.addEventListener('click', () => {
                const tabName = button.dataset.tab;
                
                // Remove active class from all tabs and contents
                document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
                
                // Add active class to clicked tab and corresponding content
                button.classList.add('active');
                document.getElementById(tabName + '-tab').classList.add('active');
            });
        });

        // Toggle Password Visibility
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const button = event.target.closest('.toggle-password');
            
            if (input.type === 'password') {
                input.type = 'text';
                button.innerHTML = '<i class="fas fa-eye-slash"></i>';
            } else {
                input.type = 'password';
                button.innerHTML = '<i class="fas fa-eye"></i>';
            }
        }
    </script>

</body>
</html>